#!/bin/bash

clear
echo "===== l-panel ====="
echo "Last update: 2026-07-17"
echo "1) Install l-panel"
echo "2) Update l-panel"
echo "3) Install ocserv 1.5.0"
echo "4) Run Web Panel"
echo "-------------------"
read -p "Choose: " CH

case $CH in
    4)
        read -p "Enter panel port (default 2096): " PANELPORT
        PANELPORT=${PANELPORT:-2096}

        echo "[+] Updating service port..."
        sed -i "s/--port [0-9]*/--port $PANELPORT/" /etc/systemd/system/lpanel.service

        systemctl daemon-reload
        echo "[+] Restarting panel service..."
        systemctl restart lpanel

        systemctl status lpanel --no-pager
        ;;
esac
