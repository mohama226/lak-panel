#!/usr/bin/env bash

set -Eeuo pipefail


SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"

BASE_DIR="$(dirname "$SCRIPT_PATH")"


source "$BASE_DIR/lib/colors.sh"
source "$BASE_DIR/lib/common.sh"
source "$BASE_DIR/lib/version.sh"


INSTALL_CMD="$BASE_DIR/commands/install.sh"
UPDATE_CMD="$BASE_DIR/commands/update.sh"
OCSERV_CMD="$BASE_DIR/commands/ocserv.sh"
UNINSTALL_CMD="$BASE_DIR/commands/uninstall.sh"


check_file(){

    if [[ ! -f "$1" ]]; then

        fail "Missing file: $1"

        exit 1

    fi

}


menu(){

clear

show_header


echo "1) Install L-Panel"

echo "2) Install Ocserv 1.5.0"

echo "3) Update L-Panel"

echo "4) Uninstall L-Panel"

echo

echo "0) Exit"

echo


read -rp "Select option: " OPTION


case "$OPTION" in


1)
check_file "$INSTALL_CMD"
bash "$INSTALL_CMD"
;;


2)
check_file "$OCSERV_CMD"
bash "$OCSERV_CMD"
;;


3)
check_file "$UPDATE_CMD"
bash "$UPDATE_CMD"
;;


4)
check_file "$UNINSTALL_CMD"
bash "$UNINSTALL_CMD"
;;


0)
exit 0
;;


*)
fail "Invalid option"
sleep 2
;;

esac


}


while true
do

menu

done
