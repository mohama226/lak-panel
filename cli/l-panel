#!/usr/bin/env bash

set -Eeuo pipefail

SOURCE="${BASH_SOURCE[0]}"

while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"

    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

source "$SCRIPT_DIR/lib/colors.sh"
source "$SCRIPT_DIR/lib/common.sh"
source "$SCRIPT_DIR/lib/version.sh"
source "$SCRIPT_DIR/commands/menu.sh"

while true
do
    show_menu

    read -rp "Select option: " OPTION

    case "$OPTION" in

        ########################
        # SYSTEM
        ########################

        1)
            bash "$SCRIPT_DIR/commands/install.sh"
        ;;

        2)
            bash "$SCRIPT_DIR/commands/update.sh"
        ;;

        3)
            bash "$SCRIPT_DIR/commands/uninstall.sh"
        ;;

        ########################
        # VPN
        ########################

        4)
            bash "$SCRIPT_DIR/commands/ocserv.sh"
        ;;

        5)
            bash "$SCRIPT_DIR/commands/status.sh"
        ;;

        6)
            systemctl restart ocserv
            pause
        ;;

        7)
            systemctl stop ocserv
            pause
        ;;

        8)
            systemctl start ocserv
            pause
        ;;

        ########################
        # USERS
        ########################

        9)
            echo "Coming Soon"
            pause
        ;;

        10)
            echo "Coming Soon"
            pause
        ;;

        11)
            echo "Coming Soon"
            pause
        ;;

        12)
            echo "Coming Soon"
            pause
        ;;

        ########################
        # SECURITY
        ########################

        13)
            echo "Coming Soon"
            pause
        ;;

        14)
            echo "Coming Soon"
            pause
        ;;

        15)
            echo "Coming Soon"
            pause
        ;;

        ########################
        # BACKUP
        ########################

        16)
            echo "Coming Soon"
            pause
        ;;

        17)
            echo "Coming Soon"
            pause
        ;;

        ########################
        # MONITORING
        ########################

        18)
            bash "$SCRIPT_DIR/commands/dashboard.sh"
        ;;

        19)
            echo "Coming Soon"
            pause
        ;;

        20)
            bash "$SCRIPT_DIR/commands/services.sh"
        ;;

        21)
            bash "$SCRIPT_DIR/commands/logs.sh"
        ;;
        22)
            echo "Coming Soon"
            pause
        ;;

        ########################

        0)
            clear
            exit 0
        ;;

        *)
            echo
            echo "Invalid option."
            pause
        ;;

    esac

done
