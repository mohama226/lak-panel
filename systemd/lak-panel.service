[Unit]
Description=LAK Panel
After=network.target


[Service]

Type=simple

WorkingDirectory=/opt/lak-panel/panel/backend

Environment=PYTHONUNBUFFERED=1

ExecStart=/opt/lak-panel/panel/backend/venv/bin/python3 /opt/lak-panel/panel/backend/run.py

Restart=always

RestartSec=5

User=root

Group=root


[Install]

WantedBy=multi-user.target
